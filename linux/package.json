{
  "name": "waifux-linux",
  "version": "38.0.94",
  "description": "WaifuX Linux 桌面应用",
  "main": "electron-main.js",
  "author": {
    "name": "WaifuX Linux",
    "email": "waifux@example.invalid"
  },
  "homepage": "https://github.com/jipika/WaifuX",
  "license": "GPL-3.0",
  "private": true,
  "scripts": {
    "start": "env -u ELECTRON_RUN_AS_NODE electron .",
    "dist:deb": "electron-builder --linux deb --x64"
  },
  "build": {
    "appId": "com.waifux.linux",
    "productName": "WaifuX",
    "artifactName": "waifux-linux-${version}-${arch}.${ext}",
    "directories": {
      "output": "../dist/electron"
    },
    "afterPack": "electron-after-pack.js",
    "files": [
      "electron-main.js",
      "electron-after-pack.js",
      "preload.js",
      "waifux-linux.js",
      "app/**/*",
      "README.md",
      "icon.png",
      "package.json"
    ],
    "linux": {
      "target": [
        "deb"
      ],
      "category": "Graphics",
      "icon": "icon.png",
      "executableName": "waifux-linux",
      "maintainer": "WaifuX Linux <waifux@example.invalid>"
    },
    "deb": {
      "depends": [
        "gsettings-desktop-schemas",
        "xdg-utils",
        "ffmpeg",
        "mpv",
        "x11-utils"
      ],
      "recommends": [
        "feh",
        "wmctrl",
        "xdotool"
      ]
    }
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  }
}
